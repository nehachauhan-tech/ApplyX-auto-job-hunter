# ===========================================
# ApplyX Environment Variables
# ===========================================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Gemini AI Configuration (for resume optimization, AI features)
# Get your API key from: https://aistudio.google.com/apikey
# SDK: @google/genai (v2.5.0+)
# See src/config/ai-models.json for available models
GEMINI_API_KEY=your_gemini_api_key

# Optional: OpenAI (legacy, not currently used)
# OPENAI_API_KEY=your_openai_api_key

# Email Configuration (for recruiter outreach)
RESEND_API_KEY=your_resend_api_key

# ===========================================
# GOOGLE OAUTH SETUP (via Supabase)
# ===========================================
#
# 1. Go to Google Cloud Console: https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Go to APIs & Services > Credentials
# 4. Create OAuth 2.0 Client ID (Web application)
# 5. Add authorized redirect URI:
#    https://YOUR_SUPABASE_PROJECT.supabase.co/auth/v1/callback
# 6. Copy Client ID and Client Secret
# 7. In Supabase Dashboard > Authentication > Providers > Google:
#    - Enable Google provider
#    - Paste Client ID and Client Secret
#
# ===========================================

# ===========================================
# DATABASE SETUP INSTRUCTIONS
# ===========================================
#
# To set up your database, run the SQL migration files
# directly in Supabase SQL Editor:
#
# 1. Go to: https://supabase.com/dashboard/project/YOUR_PROJECT/sql
# 2. Copy and paste the contents of each migration file:
#    - supabase/migrations/00001_initial_schema.sql
#    - supabase/migrations/00002_add_analytics.sql
# 3. Click "Run" to execute
#
# Migration files are located in: /supabase/migrations/
# ===========================================
