# ===========================================
# ApplyX Environment Variables
# ===========================================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OAuth Providers (Configure in Supabase Dashboard > Authentication > Providers)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI/LLM Configuration (for resume optimization)
OPENAI_API_KEY=your_openai_api_key

# Email Configuration (for recruiter outreach)
RESEND_API_KEY=your_resend_api_key

# ===========================================
# DATABASE SETUP INSTRUCTIONS
# ===========================================
#
# To set up your database, run the SQL migration files
# directly in Supabase SQL Editor:
#
# 1. Go to: https://supabase.com/dashboard/project/YOUR_PROJECT/sql
# 2. Copy and paste the contents of each migration file:
#    - supabase/migrations/00001_initial_schema.sql
#    - supabase/migrations/00002_add_analytics.sql
# 3. Click "Run" to execute
#
# Migration files are located in: /supabase/migrations/
# ===========================================
